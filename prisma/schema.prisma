// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts   TradingAccount[]
  trades     Trade[]
  journals   JournalEntry[]
  strategies Strategy[]
  metrics    PerformanceMetric[]
}

model TradingAccount {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  userId         String      @db.ObjectId
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  broker         String?
  accountType    AccountType @default(PAPER)
  initialBalance Float
  currency       String      @default("USD")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  trades  Trade[]
  metrics PerformanceMetric[]

  @@index([userId])
}

model Trade {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId String?  @db.ObjectId
  account   TradingAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  symbol    String
  assetType AssetType?
  direction TradeDirection
  status    TradeStatus    @default(OPEN)

  entryDate  DateTime
  entryPrice Float
  quantity   Float

  exitDate  DateTime?
  exitPrice Float?

  commission        Float  @default(0)
  fees              Float  @default(0)
  profitLoss        Float?
  profitLossPercent Float?

  stopLoss        Float?
  takeProfit      Float?
  riskRewardRatio Float?

  strategyId String?   @db.ObjectId
  strategy   Strategy? @relation(fields: [strategyId], references: [id], onDelete: SetNull)
  setupType  String?
  timeFrame  String?

  notes         String?
  tags          String[] @default([])
  chartImageUrl String?

  confidenceLevel Int?
  emotionalState  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([accountId])
  @@index([symbol])
  @@index([entryDate])
  @@index([status])
}

model JournalEntry {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  userId    String           @db.ObjectId
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  entryDate DateTime
  entryType JournalEntryType @default(DAILY)

  title   String?
  content String?

  whatWentWell   String?
  whatWentWrong  String?
  lessonsLearned String?

  goalsNextPeriod  String?
  marketConditions String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, entryDate, entryType])
  @@index([userId])
  @@index([entryDate])
}

model Strategy {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name                String
  description         String?
  entryRules          String?
  exitRules           String?
  riskManagementRules String?

  totalTrades   Int      @default(0)
  winningTrades Int      @default(0)
  losingTrades  Int      @default(0)
  winRate       Float?
  averageProfit Float?
  averageLoss   Float?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trades Trade[]

  @@index([userId])
}

model PerformanceMetric {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  userId    String          @db.ObjectId
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId String?         @db.ObjectId
  account   TradingAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  metricDate DateTime

  totalTrades   Int @default(0)
  winningTrades Int @default(0)
  losingTrades  Int @default(0)

  dailyPnl       Float  @default(0)
  cumulativePnl  Float  @default(0)
  accountBalance Float?

  winRate      Float?
  profitFactor Float?
  sharpeRatio  Float?
  maxDrawdown  Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, accountId, metricDate])
  @@index([userId])
  @@index([metricDate])
}

enum AccountType {
  LIVE
  DEMO
  PAPER
}

enum TradeDirection {
  LONG
  SHORT
}

enum TradeStatus {
  OPEN
  CLOSED
  PARTIAL
}

enum JournalEntryType {
  DAILY
  WEEKLY
  MONTHLY
}

enum AssetType {
  STOCK
  FOREX
  CRYPTO
  OPTIONS
  FUTURES
  OTHER
}
