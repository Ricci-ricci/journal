// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts   TradingAccount[]
  trades     Trade[]
  journals   JournalEntry[]
  strategies Strategy[]
  metrics    PerformanceMetric[]
  posts      Post[]
  likes      Like[]
  comments   Comment[]
}

model TradingAccount {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  userId         String      @db.ObjectId
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  broker         String?
  accountType    AccountType @default(PAPER)
  initialBalance Float
  currency       String      @default("USD")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  trades  Trade[]
  metrics PerformanceMetric[]

  @@index([userId])
}

model Trade {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  userId    String          @db.ObjectId
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId String?         @db.ObjectId
  account   TradingAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  symbol    String
  assetType AssetType?
  direction TradeDirection
  status    TradeStatus    @default(OPEN)

  entryDate  DateTime
  entryPrice Float
  quantity   Float

  exitDate  DateTime?
  exitPrice Float?

  commission        Float  @default(0)
  fees              Float  @default(0)
  profitLoss        Float?
  profitLossPercent Float?

  stopLoss        Float?
  takeProfit      Float?
  riskRewardRatio Float?

  strategyId String?   @db.ObjectId
  strategy   Strategy? @relation(fields: [strategyId], references: [id], onDelete: SetNull)
  setupType  String?
  timeFrame  String?

  notes         String?
  tags          String[] @default([])
  chartImageUrl String?
  posts         Post[]

  confidenceLevel Int?
  emotionalState  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([accountId])
  @@index([symbol])
  @@index([entryDate])
  @@index([status])
}

model JournalEntry {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  entryDate DateTime
  entryType JournalEntryType @default(DAILY)

  title   String?
  content String?

  whatWentWell   String?
  whatWentWrong  String?
  lessonsLearned String?

  goalsNextPeriod  String?
  marketConditions String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, entryDate, entryType])
  @@index([userId])
  @@index([entryDate])
}

model Strategy {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name                String
  description         String?
  entryRules          String?
  exitRules           String?
  riskManagementRules String?

  totalTrades   Int    @default(0)
  winningTrades Int    @default(0)
  losingTrades  Int    @default(0)
  winRate       Float?
  averageProfit Float?
  averageLoss   Float?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trades Trade[]

  @@index([userId])
}

model PerformanceMetric {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  userId    String          @db.ObjectId
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId String?         @db.ObjectId
  account   TradingAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  metricDate DateTime

  totalTrades   Int @default(0)
  winningTrades Int @default(0)
  losingTrades  Int @default(0)

  dailyPnl       Float  @default(0)
  cumulativePnl  Float  @default(0)
  accountBalance Float?

  winRate      Float?
  profitFactor Float?
  sharpeRatio  Float?
  maxDrawdown  Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, accountId, metricDate])
  @@index([userId])
  @@index([metricDate])
}

enum AccountType {
  LIVE
  DEMO
  PAPER
}

enum TradeDirection {
  LONG
  SHORT
}

enum TradeStatus {
  OPEN
  CLOSED
  PARTIAL
}

enum JournalEntryType {
  DAILY
  WEEKLY
  MONTHLY
}

model Post {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tradeId String? @db.ObjectId
  trade   Trade?  @relation(fields: [tradeId], references: [id], onDelete: SetNull)

  caption         String?
  showPnL         Boolean @default(false)
  showAccountSize Boolean @default(false)

  // Snapshot of trade data at publish time (immutable after share)
  symbol        String
  direction     TradeDirection
  assetType     AssetType?
  entryPrice    Float
  exitPrice     Float?
  profitLoss    Float?
  profitLossPct Float?
  status        TradeStatus    @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  likes    Like[]
  comments Comment[]

  @@index([userId])
  @@index([createdAt])
}

model Like {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId String @db.ObjectId
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
}

model Comment {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId String @db.ObjectId
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  content String

  createdAt DateTime @default(now())

  @@index([postId])
}

enum AssetType {
  STOCK
  FOREX
  CRYPTO
  OPTIONS
  FUTURES
  OTHER
}
